# Ergora Local Agent — copy to .env and fill in your values
# Get these from ergora.cloud/portal/settings/desktop-agent

# Your Ergora agent token (identifies you — the token alone is enough)
ERGORA_AGENT_TOKEN=your_agent_token_here

# Anthropic API key (for local agent reasoning)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Device identity (auto-generated on first run, or set manually)
# DEVICE_ID=auto
# DEVICE_NAME=My MacBook Pro

# Folders this agent is allowed to access (comma-separated absolute paths)
# MOUNTED_PATHS=/Users/you/Documents,/Users/you/Downloads

# Optional: Ergora API base URL (default: https://ergora.cloud)
# ERGORA_API_URL=https://ergora.cloud
