{
  "name": "ergora-local",
  "version": "0.1.0",
  "description": "Ergora Desktop Agent — bridges your local machine to your Ergora workspace, plus the top-of-screen HUD.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "bash scripts/setup.sh",
    "hud:install": "npm --prefix hud install",
    "hud:dev": "tauri dev --config src-tauri/tauri.conf.json",
    "hud:build": "tauri build --config src-tauri/tauri.conf.json",
    "hud:bundle:mac": "tauri build --config src-tauri/tauri.conf.json --target universal-apple-darwin",
    "tauri": "tauri --config src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "@supabase/supabase-js": "^2.101.1",
    "chokidar": "^4.0.3",
    "dotenv": "^16.5.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
