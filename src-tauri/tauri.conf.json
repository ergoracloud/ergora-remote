{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ergora HUD",
  "version": "0.1.0",
  "identifier": "cloud.ergora.hud",
  "build": {
    "beforeDevCommand": "npm --prefix hud run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm --prefix hud run build",
    "frontendDist": "../hud/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "hud",
        "title": "Ergora HUD",
        "width": 220,
        "height": 76,
        "minHeight": 76,
        "minWidth": 200,
        "maxHeight": 700,
        "maxWidth": 960,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Ergora HUD \u2014 voice + keyboard top-bar for your workspace",
    "longDescription": "Ergora HUD is the always-available top-of-screen overlay that lets you talk to your Ergora workspace from anywhere on your machine. Press the global hotkey, dictate or type, and let your Intern handle the rest.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "entitlements": null
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {}
}